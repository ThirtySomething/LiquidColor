@startuml LiquidColor Architecture
' =====================================================================
' LiquidColor – Component / Dependency Architecture
' Generated: April 2026
' Patterns: State, Command, Observer, Strategy, Facade, Repository, DI
' =====================================================================

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam ArrowColor #555555
skinparam ArrowThickness 1.2
skinparam BackgroundColor #FAFAFA
skinparam component {
  BackgroundColor #EEF4FB
  BorderColor #3A7DC9
  FontColor #1A1A1A
}
skinparam package {
  BackgroundColor #F5F5F5
  BorderColor #888888
  FontColor #333333
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}

' ─────────────────────────────────────────────────────────────────────
' PACKAGES
' ─────────────────────────────────────────────────────────────────────

package "Vue Shell" as Shell {
  [src/liquidcolor.ts] <<Entry Point>>
}

package "Composition" as Comp {
  [src/boarddependencies.ts] <<DI Helper>>
}

package "Core Domain" as Domain {
  [src/board.ts]       <<Singleton>>
  [src/player.ts]
  [src/grid.ts]
  [src/cell.ts]
  [src/gamephase.ts]   <<State Pattern>>
  [src/definitions.ts]
}

package "Commands" as Cmds {
  [src/commands/commandinvoker.ts]  <<Invoker>>
  [src/commands/commandplaycolor.ts] <<Concrete Command\n(delta-based undo)>>
  [src/commands/commandresetgame.ts] <<Concrete Command>>
  [src/commands/icommand.ts]         <<interface>>
}

package "AI Strategies" as Strat {
  [src/strategies/computerstrategyfactory.ts] <<Factory>>
  [src/strategies/strategygreedy.ts]          <<Strategy>>
  [src/strategies/strategyminimax.ts]         <<Strategy>>
  [src/strategies/capturesimulator.ts]        <<Helper>>
  [src/strategies/icomputerstrategy.ts]       <<interface>>
  [src/strategies/computerstrategytype.ts]    <<enum/type>>
  [src/strategies/strategyinput.ts]           <<type>>
}

package "Infrastructure / UI" as Infra {
  [src/uifacade.ts]       <<Facade>>
  [src/util.ts]           <<Delegating Wrapper>>
  [src/timer.ts]          <<Timer + Runtime>>
  [src/subject.ts]        <<Observable>>
  [src/scoreobserver.ts]  <<Observer>>
  [src/winnerobserver.ts] <<Observer>>
  [src/iobserver.ts]      <<interface>>
  [src/observerdata.ts]   <<Data Types>>
}

package "Persistence" as Persist {
  [src/highscore.ts]                    <<Domain + Interface>>
  [src/localstoragehighscorerepository.ts] <<Repository Impl>>
  [src/highscorewinner.ts]              <<Value Type>>
}

package "Shared Types" as Types {
  [src/randomsource.ts]  <<DI / Interface>>
  [src/offset.ts]        <<Value Type>>
  [src/types/*]          <<Type Definitions>>
}

' ─────────────────────────────────────────────────────────────────────
' DEPENDENCY ARROWS
' ─────────────────────────────────────────────────────────────────────

' Shell → everything it composes at startup
[src/liquidcolor.ts] --> [src/board.ts]               : creates Board
[src/liquidcolor.ts] --> [src/boarddependencies.ts]   : createBoardDependencies()
[src/liquidcolor.ts] --> [src/commands/commandresetgame.ts]    : registers reset command
[src/liquidcolor.ts] --> [src/player.ts]              : creates human/computer
[src/liquidcolor.ts] --> [src/definitions.ts]         : game config
[src/liquidcolor.ts] --> [src/scoreobserver.ts]       : attaches observer
[src/liquidcolor.ts] --> [src/winnerobserver.ts]      : attaches observer

' Composition helper → infrastructure dependencies it wires
[src/boarddependencies.ts] --> [src/localstoragehighscorerepository.ts] : default repo
[src/boarddependencies.ts] --> [src/randomsource.ts]  : MathRandomSource
[src/boarddependencies.ts] --> [src/timer.ts]         : BrowserTimerRuntime

' Core Domain – Board orchestrates everything
[src/board.ts] --> [src/commands/commandinvoker.ts]    : executes commands
[src/board.ts] --> [src/commands/commandplaycolor.ts]  : creates commands
[src/board.ts] --> [src/player.ts]            : human + computer
[src/board.ts] --> [src/grid.ts]              : game board cells
[src/board.ts] --> [src/gamephase.ts]         : phase transitions
[src/board.ts] --> [src/definitions.ts]       : config
[src/board.ts] --> [src/highscore.ts]         : persist scores
[src/board.ts] --> [src/timer.ts]             : game timer
[src/board.ts] --> [src/uifacade.ts]          : DOM updates
[src/board.ts] --> [src/util.ts]              : helper DOM ops
[src/board.ts] --> [src/subject.ts]           : notifies observers
[src/board.ts] --> [src/randomsource.ts]      : injectable random

' Player uses strategies and triggers observers
[src/player.ts] --> [src/strategies/computerstrategyfactory.ts] : gets AI strategy
[src/player.ts] --> [src/cell.ts]                    : reads board cells
[src/player.ts] --> [src/definitions.ts]             : config
[src/player.ts] --> [src/observerdata.ts]            : score events
[src/player.ts] --> [src/util.ts]                    : UI helper
[src/player.ts] --> [src/randomsource.ts]            : injectable random

' Grid and Cell
[src/grid.ts] --> [src/cell.ts]          : contains cells
[src/grid.ts] --> [src/definitions.ts]   : grid dimensions
[src/grid.ts] --> [src/randomsource.ts]  : injectable random
[src/cell.ts] --> [src/definitions.ts]   : color list
[src/cell.ts] --> [src/randomsource.ts]  : injectable random

' Commands
[src/commands/commandinvoker.ts]   --> [src/commands/icommand.ts]
[src/commands/commandplaycolor.ts] --> [src/board.ts]     : snapshot + restore
[src/commands/commandplaycolor.ts] --> [src/commands/icommand.ts]
[src/commands/commandresetgame.ts] --> [src/board.ts]     : resets game state
[src/commands/commandresetgame.ts] --> [src/commands/icommand.ts]

' AI Strategies
[src/strategies/computerstrategyfactory.ts] --> [src/strategies/strategygreedy.ts]    : creates
[src/strategies/computerstrategyfactory.ts] --> [src/strategies/strategyminimax.ts]   : creates
[src/strategies/computerstrategyfactory.ts] --> [src/strategies/icomputerstrategy.ts]
[src/strategies/computerstrategyfactory.ts] --> [src/strategies/computerstrategytype.ts]
[src/strategies/computerstrategyfactory.ts] --> [src/randomsource.ts]
[src/strategies/strategygreedy.ts]   --> [src/strategies/capturesimulator.ts]
[src/strategies/strategygreedy.ts]   --> [src/strategies/icomputerstrategy.ts]
[src/strategies/strategygreedy.ts]   --> [src/strategies/strategyinput.ts]
[src/strategies/strategygreedy.ts]   --> [src/cell.ts]
[src/strategies/strategygreedy.ts]   --> [src/randomsource.ts]
[src/strategies/strategyminimax.ts]  --> [src/strategies/capturesimulator.ts]
[src/strategies/strategyminimax.ts]  --> [src/strategies/icomputerstrategy.ts]
[src/strategies/strategyminimax.ts]  --> [src/strategies/strategyinput.ts]
[src/strategies/strategyminimax.ts]  --> [src/cell.ts]
[src/strategies/strategyminimax.ts]  --> [src/randomsource.ts]
[src/strategies/capturesimulator.ts] --> [src/cell.ts]
[src/strategies/capturesimulator.ts] --> [src/definitions.ts]
[src/strategies/icomputerstrategy.ts] --> [src/strategies/strategyinput.ts]

' Infrastructure – Observer chain
[src/subject.ts]        --> [src/iobserver.ts]
[src/subject.ts]        --> [src/observerdata.ts]
[src/scoreobserver.ts]  --> [src/iobserver.ts]
[src/scoreobserver.ts]  --> [src/observerdata.ts]
[src/winnerobserver.ts] --> [src/iobserver.ts]
[src/winnerobserver.ts] --> [src/observerdata.ts]
[src/iobserver.ts]      --> [src/observerdata.ts]
[src/timer.ts]          --> [src/util.ts]

' UI Facade chain
[src/util.ts] --> [src/uifacade.ts] : delegates all DOM ops

' Persistence chain
[src/highscore.ts]                      --> [src/highscorewinner.ts]
[src/highscore.ts]                      --> [src/localstoragehighscorerepository.ts]
[src/highscore.ts]                      --> [src/util.ts]
[src/localstoragehighscorerepository.ts] --> [src/highscore.ts] : implements HighscoreRepository

' Shared Types
[src/definitions.ts] --> [src/offset.ts]

' ─────────────────────────────────────────────────────────────────────
' PATTERN LEGEND
' ─────────────────────────────────────────────────────────────────────

legend right
  Design Patterns Used
  ─────────────────────────────
  State        src/gamephase.ts
  Command      src/commands/ package
  Observer     subject, *observer
  Strategy     src/strategies/ package
  Facade       src/uifacade.ts
  Repository   HighscoreRepository
  Singleton    Board
  Factory      ComputerStrategyFactory
  DI           RandomSource, TimerRuntime
               HighscoreRepository
  ─────────────────────────────
  Delta undo/redo: CommandPlayColor
  stores only changed cells
  ─────────────────────────────
  Unlimited undo/redo stack:
  CommandInvoker (no cap)
endlegend

@enduml
