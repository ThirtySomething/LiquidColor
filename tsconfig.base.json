{
    "compilerOptions": {
        "target": "ES2023",
        "module": "es2022",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "verbatimModuleSyntax": true,
        "lib": [
            "ES2023",
            "DOM",
            "DOM.Iterable"
        ],
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "noEmitOnError": true,
        "outDir": "dist",
        "incremental": true,
        "skipLibCheck": true
    },
    "files": [
        "vue-compiler-build.d.ts",
        "src/util.ts",
        "src/uifacade.ts",
        "src/offset.ts",
        "src/definitions.ts",
        "src/cell.ts",
        "src/grid.ts",
        "src/highscorewinner.ts",
        "src/highscore.ts",
        "src/localstoragehighscorerepository.ts",
        "src/gamephase.ts",
        "src/player.ts",
        "src/board.ts",
        "src/boarddependencies.ts",
        "src/liquidcolor.ts"
    ]
}
