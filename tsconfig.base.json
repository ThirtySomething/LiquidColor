{
    "compilerOptions": {
        "target": "ES2023",
        "module": "es2022",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "verbatimModuleSyntax": true,
        "lib": [
            "ES2023",
            "DOM",
            "DOM.Iterable"
        ],
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "noEmitOnError": true,
        "outDir": "dist",
        "incremental": true,
        "skipLibCheck": true
    },
    "files": [
        "vue-compiler-build.d.ts",
        "util.ts",
        "offset.ts",
        "definitions.ts",
        "cell.ts",
        "grid.ts",
        "highscorewinner.ts",
        "highscore.ts",
        "gamephase.ts",
        "player.ts",
        "board.ts",
        "liquidcolor.ts"
    ]
}
